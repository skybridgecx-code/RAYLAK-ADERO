{
  "name": "raylak",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build",
    "check:adero-deploy": "pnpm --filter @adero/web check:deployment-env",
    "check:admin-auth": "pnpm --filter @adero/web check:admin-auth",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "validate": "pnpm check:admin-auth && pnpm typecheck && pnpm lint && SKIP_ENV_VALIDATION=1 pnpm build",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "db:generate": "turbo run db:generate --filter=@raylak/db",
    "db:migrate": "turbo run db:migrate --filter=@raylak/db",
    "db:studio": "turbo run db:studio --filter=@raylak/db"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
